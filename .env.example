# Copie este arquivo para .env e ajuste os valores
# NUNCA suba o .env real para o git

# Em produção, gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-isto-em-producao

# SQLite local — fica em instance/moviechoice.db
DATABASE_URL=sqlite:///moviechoice.db

# Em produção, restrinja para o domínio real do seu front-end
CORS_ORIGINS=*

# Porta onde o Flask vai rodar
PORT=5000
